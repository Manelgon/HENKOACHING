# =============================================================================
# VARIABLES DE ENTORNO — Plantilla
# =============================================================================
# Copia este archivo como .env.local y rellena con tus valores.
# NUNCA subas .env.local al repositorio (ya está en .gitignore).

# --- Supabase (cliente público) ---
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Supabase (servidor, NUNCA exponer al cliente) ---
# Necesaria para acciones admin: borrado de usuarios, cron de retención, audit logs.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Site URL (requerido para OAuth redirects) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Cron de retención RGPD ---
# Cadena aleatoria larga. Vercel la usará como Bearer token al disparar /api/cron/retencion.
# Generar con: $bytes = New-Object byte[] 32; [Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($bytes); [Convert]::ToHexString($bytes).ToLower()
CRON_SECRET=your_random_secret_here

# --- OpenAI (opcional, si se usan features de IA) ---
# OPENAI_API_KEY=your_openai_api_key

# --- Google OAuth ---
# Se configura en Supabase Dashboard, NO aquí.
# Ver: Supabase Dashboard > Authentication > Providers > Google
